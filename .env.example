WEBSHELL_ENVIRONMENT=development
WEBSHELL_DATA_DIR=.data
WEBSHELL_DATABASE_URL=sqlite+aiosqlite:///.data/webshell.db
WEBSHELL_CREDENTIAL_KEY_PATH=.data/credentials.key
WEBSHELL_COOKIE_SECURE=false
WEBSHELL_AUTO_CREATE_SCHEMA=true
WEBSHELL_ENFORCE_DESTINATION_RULES=false
WEBSHELL_TMUX_HISTORY_LIMIT=50000
WEBSHELL_TRUSTED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
WEBSHELL_MAX_TERMINALS_PER_USER=5
WEBSHELL_MAX_UPLOAD_BYTES=21474836480
