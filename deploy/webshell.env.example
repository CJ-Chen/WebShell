WEBSHELL_ENVIRONMENT=production
WEBSHELL_DATA_DIR=/var/lib/webshell
WEBSHELL_DATABASE_URL=sqlite+aiosqlite:////var/lib/webshell/webshell.db
WEBSHELL_CREDENTIAL_KEY_PATH=/etc/webshell/credentials.key
WEBSHELL_COOKIE_SECURE=true
WEBSHELL_AUTO_CREATE_SCHEMA=false
WEBSHELL_ENFORCE_DESTINATION_RULES=false
WEBSHELL_TMUX_HISTORY_LIMIT=50000
WEBSHELL_TRUSTED_ORIGINS=["https://webshell.example.com"]
WEBSHELL_MAX_TERMINALS_PER_USER=5
WEBSHELL_MAX_UPLOAD_BYTES=21474836480
